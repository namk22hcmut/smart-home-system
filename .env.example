# ========================================
# Backend Configuration
# ========================================

# Flask Environment (development, production, testing)
FLASK_ENV=development

# Database Configuration
DATABASE_URL=sqlite:///smarthome.db
# For PostgreSQL: postgresql://user:password@localhost:5432/smart_home
SQLALCHEMY_ECHO=False

# Security Keys (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-key-here-change-in-production

# Adafruit IoT Configuration
ADAFRUIT_USERNAME=your-adafruit-username
ADAFRUIT_KEY=your-adafruit-api-key

# Backend API Configuration
BACKEND_API_URL=http://localhost:8000

# ========================================
# Mobile App Configuration (Expo)
# ========================================

# Backend API URL for mobile app
EXPO_PUBLIC_API_URL=http://localhost:8000/api
# For physical devices on same network: http://YOUR_COMPUTER_IP:8000/api
# For Android emulator: http://10.0.2.2:8000/api
# For iOS simulator: http://localhost:8000/api
