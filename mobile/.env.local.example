# Mobile App Configuration Template
# COPY this file to .env.local and update with YOUR API URL
# This file (.env.local.example) WILL be committed
# But .env.local file will be gitignored

# Backend API URL - UPDATE with your backend IP/URL
# =========================================

# Option 1: Localhost (if running app on same machine as backend)
# EXPO_PUBLIC_API_URL=http://localhost:8000/api

# Option 2: Same LAN (physical device or different machine)
# Replace YOUR_BACKEND_IP with actual IP (e.g., 192.168.1.100, 10.0.106.239)
EXPO_PUBLIC_API_URL=http://YOUR_BACKEND_IP:8000/api

# Option 3: Android Emulator (special IP for emulator -> host machine)
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000/api

# Option 4: iOS Simulator
# EXPO_PUBLIC_API_URL=http://localhost:8000/api

# =========================================
# HOW TO FIND YOUR BACKEND IP (Windows):
# 1. Open Command Prompt / PowerShell
# 2. Type: ipconfig
# 3. Look for "IPv4 Address" under your network adapter
# 4. Example: 192.168.1.100 or 10.0.106.239
